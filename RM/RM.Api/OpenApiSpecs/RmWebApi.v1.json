        "tags": [
          "WorkTypes"
        ],
        "summary": "Удаляет вид работ.",
        "operationId": "DeleteWorkTypeAsync",
        "parameters": [
          {
            "name": "workTypeId",
            "in": "path",
            "description": "ИД удаляемого вида работ.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }

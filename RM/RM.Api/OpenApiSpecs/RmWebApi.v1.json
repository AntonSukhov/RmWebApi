      "get": {
        "tags": [
          "WorkTypes"
        ],
        "summary": "Предоставляет вид работ по его ИД.",
        "operationId": "GetWorkTypeAsync",
        "parameters": [
          {
            "name": "workTypeId",
            "in": "path",
            "description": "ИД вида работ.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/WorkTypeResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkTypeResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkTypeResponse"
                }
              }
            }
          }
        }
      },

            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkTypeUpdationRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/WorkTypeUpdationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
